{
  "id": "biquge_example",
  "name": "笔趣阁示例",
  "base_url": "https://example.com",
  "detail_page": {
    "title_selector": "#bookinfo h1",
    "author_selector": "#bookinfo .author",
    "chapter_list_selector": "#chapterlist li a",
    "chapter_link_attr": "href"
