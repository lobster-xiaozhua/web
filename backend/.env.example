# ===== 星穹书阁 v1.5.0 配置 =====

# 数据库配置
# 留空则自动检测: 有PostgreSQL用PostgreSQL，否则用SQLite
# DATABASE_TYPE: auto | postgres | sqlite
DATABASE_TYPE=auto
DATABASE_URL=

# Redis配置 (不可用时自动降级为内存缓存)
REDIS_URL=redis://localhost:6379/0

# Elasticsearch配置 (不可用时自动降级为数据库搜索)
ES_URL=http://localhost:9200

# 安全配置 (生产环境务必修改!)
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 应用配置
BOOKS_DIR=./books
DATA_DIR=./data
CRAWLER_GRPC_ADDR=localhost:50051
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost:3001"]

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 速率限制
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60

# 数据库连接池 (仅PostgreSQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# 缓存TTL (秒)
CACHE_TTL=300

# 搜索降级
SEARCH_FALLBACK=true
